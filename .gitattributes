# Auto detect text files and perform LF normalization
* text=auto

# Line endings that must survive Windows checkouts
# ================================================
# Shell scripts must be LF — CRLF breaks /bin/sh on the NAS.
*.sh     text eol=lf
# Windows batch files must be CRLF.
*.bat    text eol=crlf

# Source files
# ============
*.pxd    text diff=python
*.py     text diff=python
*.py3    text diff=python
*.pyw    text diff=python
*.pyx    text diff=python
*.pyz    text diff=python
*.pyi    text diff=python
*.spec   text diff=python

# Binary files
# ============
*.db     binary
*.p      binary
*.pkl    binary
*.pickle binary
*.pyc    binary export-ignore
*.pyo    binary export-ignore
*.pyd    binary
